FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    pkg-config \
    libgrpc++-dev \
    libprotobuf-dev \
    protobuf-compiler-grpc \
    uuid-dev \
    curl \
    net-tools \
    iputils-ping \
    vim \
    nano \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy distributed core library
COPY distributed_core/ /app/distributed_core/
RUN cd distributed_core && make clean && make all

# Copy necessary files
COPY include/ /app/include/
COPY src/distributed_client.cpp /app/src/
COPY proto/ /app/proto/
COPY Makefile /app/

# Clean proto files and build
RUN rm -f /app/proto/*.pb.h /app/proto/*.pb.cc
RUN make directories
RUN make proto
RUN make distributed-client

# Create a helpful startup script
RUN echo '#!/bin/bash' > /usr/local/bin/fs-test && \
    echo 'echo "========================================="' >> /usr/local/bin/fs-test && \
    echo 'echo " Distributed Filesystem Test Client"' >> /usr/local/bin/fs-test && \
    echo 'echo "========================================="' >> /usr/local/bin/fs-test && \
    echo 'echo ""' >> /usr/local/bin/fs-test && \
    echo 'echo "Available commands:"' >> /usr/local/bin/fs-test && \
    echo 'echo "  mkdir <parent_path> <dirname>              - Create directory"' >> /usr/local/bin/fs-test && \
    echo 'echo "  create <parent_path> <filename>            - Create file"' >> /usr/local/bin/fs-test && \
    echo 'echo "  rm <file_path>                             - Delete file"' >> /usr/local/bin/fs-test && \
    echo 'echo "  rmdir <directory_path>                     - Delete empty directory"' >> /usr/local/bin/fs-test && \
    echo 'echo "  write <file_path> <text> [offset]          - Write text to file"' >> /usr/local/bin/fs-test && \
    echo 'echo "  read <file_path> [offset] [size]           - Read file contents"' >> /usr/local/bin/fs-test && \
    echo 'echo "  ls <directory_path>                        - List directory"' >> /usr/local/bin/fs-test && \
    echo 'echo ""' >> /usr/local/bin/fs-test && \
    echo 'echo "Frontend servers available:"' >> /usr/local/bin/fs-test && \
    echo 'echo "  - frontend-1:60051"' >> /usr/local/bin/fs-test && \
    echo 'echo "  - frontend-2:60052"' >> /usr/local/bin/fs-test && \
    echo 'echo "  - frontend-3:60053"' >> /usr/local/bin/fs-test && \
    echo 'echo ""' >> /usr/local/bin/fs-test && \
    echo 'echo "Usage: /app/bin/distributed_client <frontend-host:port> <command> [args...]"' >> /usr/local/bin/fs-test && \
    echo 'echo "Example: /app/bin/distributed_client frontend-1:60051 write /mydir/file.txt \"hello\""' >> /usr/local/bin/fs-test && \
    echo 'echo ""' >> /usr/local/bin/fs-test && \
    chmod +x /usr/local/bin/fs-test

# Keep container running
CMD ["tail", "-f", "/dev/null"]
