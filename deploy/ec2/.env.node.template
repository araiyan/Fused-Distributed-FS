# Copy this file to .env.node1 / .env.node2 / .env.node3 and update values.
# Use Elastic IP or DNS names so peers can reach each other cross-region.

# This node identity (must be unique: 1, 2, 3)
NODE_ID=1
TOTAL_NODES=3

# Internal container ports (usually keep defaults)
LISTEN_PORT=8001
FRONTEND_GRPC_PORT=60051
STORAGE_PORT=9000
GRPC_PORT=50051

# Paxos proposal timeout in milliseconds.
# Cross-region deployments usually need higher values than local Docker.
PAXOS_PROPOSAL_TIMEOUT_MS=8000

# Publicly exposed host ports on this EC2 instance
PUBLIC_FRONTEND_GRPC_PORT=60051
PUBLIC_FRONTEND_P2P_PORT=8001
PUBLIC_STORAGE_TCP_PORT=9000
PUBLIC_STORAGE_GRPC_PORT=50051

# Frontend Paxos peers: <peer_node_id>@<peer_public_ip_or_dns>:8001
# IMPORTANT: Quote values because there are spaces between peers.
# Example for NODE_ID=1:
# PEER_NODES="2@34.201.10.12:8001 3@3.91.20.55:8001"
PEER_NODES=""

# Storage targets used by this frontend for file read/write quorum.
# Include all 3 storage nodes as <public_ip_or_dns>:9000
# IMPORTANT: Quote values because there are spaces between nodes.
# Example:
# STORAGE_NODES="18.211.1.10:9000 34.201.10.12:9000 3.91.20.55:9000"
STORAGE_NODES=""
